 in the keys of values)\n            put values[i] & COMMA & SPACE after tSQL\n         end repeat\n         delete char -2 to -1 of tSQL\n         put \")\" after tSQL\n         revExecuteSQL databaseID, tSQL\n         return the result\n      else\n         throw \"Database is not open.\"\n      end if\n   catch errorParam\n      throw errorParam\n   end try\nend DBTableCreate\n\n\ncommand DBInsert databaseID, tableName, columnName, columnValue, databaseType\n   try\n      if _DBIsOpen(databaseID) then\n         local tSQL\n         put \"INSERT INTO\" && tableName & SPACE into tSQL\n         if (databaseType = \"PostgreSQL\") then\n            put \"(\" & columnName & \")\" & SPACE after tSQL\n         else\n            put \"(`\" & columnName & \"`)\" & SPACE after tSQL\n         end if\n         --         put \"(`\" & columnName & \"`)\" & SPACE after sql\n         put \"VALUES (\" & columnValue & \")\" after tSQL\n         --         put \"insert into\" && tableName && \"(\" into sql\n         --         repeat with i = 1 to (the number of lines in the keys of columnNames)\n         --            put columnNames[i] & COMMA & SPACE after sql\n         --         end repeat\n         --         delete char -2 to -1 of sql\n         --         put \") values (\" after sql\n         --         repeat with i = 1 to (the number of lines in the keys of insertValues)\n         --            put \":\" & i & COMMA & SPACE after sql\n         --         end repeat\n         --         delete char -2 to -1 of sql  -- remove the trailing comma and space\n         --         put \")\" after sql\n         revExecuteSQL databaseID, tSQL  //, \"columnValue\"  //, \"insertValues\"\n      else\n         throw \"Database is not open\"\n      end if\n   catch errorParamater\n      break\n   end try\nend DBInsert\n\n\ncommand DBModifyColumnForSQLite databaseID, tableName, columnName, columnDataType\n   try\n      if (_DBIsOpen(databaseID)) then\n         --         revExecuteSQL databaseID, \"BEGIN TRANSACTION;\"\n         local tSQL\n         put \"select sql from sqlite_master where type = 'table' and name ='\" & tableName & \"'\" into tSQL\n         local createTableSQL\n         put revDataFromQuery(,, databaseID, tSQL) into createTableSQL\n         local itemNumber\n         put itemOffset(columnName, createTableSQL) into itemNumber\n         if (itemNumber > 0) then  // if it is 0 then deleting a column that wasn't saved to the table\n            local columnNames\n            put revDatabaseColumnNames(databaseID, tableName) into columnNames\n            // rename the existing table to \"tmp\"\n            DBTableRename databaseID, tableName, \"tmp\"\n            // recreate the original table\n            put QUOTE & columnName & QUOTE && columnDataType into item itemNumber of createTableSQL\n            if (character -1 of createTableSQL <> \")\") then put \")\" after createTableSQL\n            revExecuteSQL databaseID, createTableSQL\n            // insert the data from the original table into the temporary table\n            put \"INSERT INTO tmp SELECT \" & columnNames & \" FROM \" & tableName into tSQL\n            revExecuteSQL databaseID, tSQL\n            // insert the data back into the main table\n            put \"INSERT INTO \" & tableName & \" SELECT \" & columnNames & \" FROM tmp\" into tSQL\n            revExecuteSQL databaseID, tSQL\n            // delete the temporary table\n            put \"DROP TABLE tmp\" into tSQL\n            revExecuteSQL databaseID, tSQL\n         end if\n         --         revExecuteSQL databaseID, \"COMMIT;\"\n      end if\n   end try\nend DBModifyColumnForSQLite\n\n\ncommand DBUpdate databaseID, tableName, columnName, columnValue, whereName, whereValue\n   try\n      if (_DBIsOpen(databaseID)) then\n         local tSQL\n         put \"UPDATE\" && tableName && \"SET \" into tSQL\n         put columnName & \"=\" & _DBQuote(columnValue) & SPACE after tSQL\n         put \"WHERE \" & whereName & \"=\" & whereValue after tSQL\n         revExecuteSQL databaseID, tSQL\n      end if\n   end try\nend DBUpdate\n\n\ncommand DBUpdateBLOB databaseID, tableName, columnName, columnValue, whereName, whereValue\n   try\n      if (_DBIsOpen(databaseID)) then\n         local tSQL\n         put \"UPDATE\" && tableName && \"SET \" into tSQL\n         put columnName & \"= :1\" after tSQL\n         put \" WHERE \" & whereName & \"=\" & whereValue after tSQL\n         revExecuteSQL databaseID, tSQL, \"*bcolumnValue\"\n      end if\n   end try\nend DBUpdateBLOB\n\n\ncommand DBUpdateBooleanForMySQL databaseID, tableName, columnName, columnValue, whereName, whereValue\n   try\n      if (_DBIsOpen(databaseID)) then\n         local tSQL\n         put \"UPDATE\" && tableName && \"SET \" into tSQL\n         put columnName & \"=\" & columnValue & SPACE after tSQL\n         put \"WHERE \" & whereName & \"=\" & whereValue after tSQL\n         revExecuteSQL databaseID, tSQL\n      end if\n   end try\nend DBUpdateBooleanForMySQL\n\n\ncommand DBDelete databaseID, tableName, whereName, whereValue\n   try\n      if (_DBIsOpen(databaseID)) then\n         local tSQL\n         put \"DELETE FROM\" && tableName && \"WHERE \" into tSQL\n         put whereName && \"=\" && _DBQuote(whereValue) after tSQL\n         --         put (line 1 of the keys of where) & \"=\" & _DBQuote(where[line 1 of the keys of where]) after sql\n         revExecuteSQL databaseID, tSQL\n      end if\n   end try\nend DBDelete\n\n\ncommand DBClose databaseID\n   if (databaseID is a number) AND (_DBIsOpen(databaseID)) then\n      revCloseDatabase databaseID\n   end if\nend DBClose\n\n\ncommand DBColumnAdd databaseID, tableName, columnSchema\n   try\n      if (_DBIsOpen(databaseID)) then\n         local tSQL\n         put \"ALTER TABLE\" && tableName && \"ADD COLUMN\" && columnSchema into tSQL\n         revExecuteSQL databaseID, tSQL\n      end if\n   end try\nend DBColumnAdd\n\n\ncommand DBColumnDrop databaseID, tableName, values\n   try\n      if (_DBIsOpen(databaseID)) then\n         local tSQL\n         put \"ALTER TABLE\" && tableName && \"DROP COLUMN\" && values into tSQL\n         revExecuteSQL databaseID, tSQL\n      end if\n   end try\nend DBColumnDrop\n\n\ncommand DBColumnModify databaseID, tableName, values\n   try\n      if (_DBIsOpen(databaseID)) then\n         local tSQL\n         put \"ALTER TABLE\" && tableName && \"MODIFY COLUMN\" && values into tSQL\n         revExecuteSQL databaseID, tSQL\n      end if\n   end try\nend DBColumnModify\n\n\ncommand DBDropColumnForSQLite databaseID, tableName, columnName\n   try\n      if (_DBIsOpen(databaseID)) then\n         --         revExecuteSQL databaseID, \"BEGIN TRANSACTION;\"\n         local tSQL\n         put \"select sql from sqlite_master where type = 'table' and name ='\" & tableName & \"'\" into tSQL\n         local createTableSQL\n         put revDataFromQuery(,, databaseID, tSQL) into createTableSQL\n         local itemNumber\n         put itemOffset(columnName, createTableSQL) into itemNumber\n         if (itemNumber > 0) then  // if it is 0 then deleting a column that wasn't saved to the table\n            // create the temporary table\n            delete item itemNumber in createTableSQL\n            if (char -1 of createTableSQL <> \")\") then put \")\" after createTableSQL\n            replace tableName with tableName & \"_backup\" in createTableSQL\n            replace \"CREATE TABLE\" with \"CREATE TEMPORARY TABLE\" in createTableSQL\n            revExecuteSQL databaseID, createTableSQL\n            // insert the data from the original table into the temporary table\n            local columnNames\n            put revDatabaseColumnNames(databaseID, tableName) into columnNames\n            put itemOffset(columnName, columnNames) into itemNumber\n            delete item itemNumber in columnNames\n            put \"INSERT INTO \" & tableName & \"_backup SELECT \" & columnNames & \" FROM \" & tableName into tSQL\n            revExecuteSQL databaseID, tSQL\n            // drop the original table\n            put \"DROP TABLE \" & tableName into tSQL\n            revExecuteSQL databaseID, tSQL\n            // recreate the original table (dbdMainTable)\n            replace \"CREATE TEMPORARY TABLE\" with \"CREATE TABLE\" in createTableSQL\n            replace tableName & \"_backup\" with tableName in createTableSQL\n            revExecuteSQL databaseID, createTableSQL\n            // insert the data back into the main table\n            put \"INSERT INTO \" & tableName & \" SELECT \" & columnNames & \" FROM \" & tableName & \"_backup\" into tSQL\n            revExecuteSQL databaseID, tSQL\n            // delete the temporary table\n            put \"DROP TABLE \" & tableName & \"_backup\" into tSQL\n            revExecuteSQL databaseID, tSQL\n         end if\n         --         revExecuteSQL databaseID, \"COMMIT;\"\n      end if\n   end try\nend DBDropColumnForSQLite\n\n\ncommand DBTableRename databaseID, tableName, newTableName\n   try\n      if (_DBIsOpen(databaseID)) then\n         local tSQL\n         put \"ALTER TABLE\" && tableName && \"RENAME TO\" && newTableName into tSQL\n         revExecuteSQL databaseID, tSQL\n      end if\n   end try\nend DBTableRename\n\n\ncommand DBColumnRename databaseID, tableName, columnName, newColumnName\n   try\n      if (_DBIsOpen(databaseID)) then\n         local tSQL\n         put \"ALTER TABLE\" && tableName && \"RENAME COLUMN\" && columnName && \"TO\" && newColumnName into tSQL\n         revExecuteSQL databaseID, tSQL\n         return the result\n      end if\n   end try\nend DBColumnRename\n\n\ncommand DBRenameColumnForMySQL databaseID, tableName, columnName, newColumnName, fieldType\n   try\n      if (_DBIsOpen(databaseID)) then\n         local tSQL\n         put \"ALTER TABLE\" && tableName && \"CHANGE\" && columnName && newColumnName && fieldType into tSQL\n         revExecuteSQL databaseID, tSQL\n         return the result\n      end if\n   end try\nend DBRenameColumnForMySQL\n\n\ncommand DBCommit databaseID\n   revCommitDatabase databaseID\nend DBCommit\n   \n   \nfunction DBRecordSetCreate databaseID, query\n   try\n      if (_DBIsOpen(databaseID)) then\n         local recordSetID\n         put revQueryDatabase(databaseID, query) into recordSetID\n         return recordSetID\n      end if\n   end try\nend DBRecordSetCreate\n\n\nfunction DBRecordSetCount recordSetID\n   try\n      local recordSetCount\n      put revNumberOfRecords(recordSetID) into recordSetCount\n      if (recordSetCount is a number) then\n         return recordSetCount\n      else\n         throw recordSetCount  // this holds an error message\n      end if\n   end try\nend DBRecordSetCount\n\n\ncommand DBRecordSetClose recordSetID\n   try\n      if (recordSetID is a number) then\n         revCloseCursor recordSetID\n      end if\n   end try\nend DBRecordSetClose\n\n\nfunction DBRecordIsFirst recordSetID\n   try\n      local recordIsFirst\n      put revCurrentRecordIsFirst(recordSetID) into recordIsFirst\n      if (item 1 of recordIsFirst = \"revdberr\") then\n         throw recordIsFirst  // this holds an error message\n      else\n         return recordIsFirst\n      end if\n   end try\nend DBRecordIsFirst\n\n\nfunction DBRecordIsLast recordSetID\n   try\n      local recordIsLast\n      put revCurrentRecordIsLast(recordSetID) into recordIsLast\n      if (item 1 of recordIsLast = \"revdberr\") then\n         throw recordIsLast\n      else\n         return recordIsLast\n      end if\n   end try\nend DBRecordIsLast\n\n\ncommand DBMoveToNextRecord recordSetID\n   try\n      revMoveToNextRecord recordSetID\n   end try\nend DBMoveToNextRecord\n\n\ncommand DBMoveToPreviousRecord recordSetID\n   try\n      revMoveToPreviousRecord recordSetID\n   end try\nend DBMoveToPreviousRecord\n\n\ncommand DBMoveToRecord recordSetID, recordNumber\n   try\n      revMoveToRecord recordSetID, recordNumber  // if this isn't supported by the database driver it'll fail, but no error is thrown\n   end try\nend DBMoveToRecord\n\n\ncommand DBMoveToFirstRecord recordSetID\n   try\n      revMoveToFirstRecord recordSetID\n   end try\nend DBMoveToFirstRecord\n\n\ncommand DBMoveToLastRecord recordSetID\n   try\n      revMoveToLastRecord recordSetID\n   end try\nend DBMoveToLastRecord\n\n\nfunction _DBIsOpen databaseID\n   local openDatabases\n   put revOpenDatabases() into openDatabases\n   \n   if (item 1 of openDatabases = \"revdberr\") then\n      throw openDatabases\n   else\n      return (databaseID is among the items of openDatabases)\n   end if\nend _DBIsOpen\n\n\nfunction _DBQuote values\n   if (values is a number) then\n      return values\n   else\n      replace \"'\" with \"''\" in values\n      return \"'\" & values & \"'\"\n   end if\nend _DBQuote\n\n","foregroundColor": "","rect": "233,112,633,512","textSize": "","textStyle": "","customPropertySets": {"cREVGeneral": {"breakpointstates": "","breakpoints": "","breakpointconditions": "","scripteditorselection": "10007","scalefactor": "1","scripteditorvscroll": "4097"}},"resizable": "true","title": "","cantDelete": "false","cantModify": "false","shadow": "true","backgroundColor": "","textFont": "","cards": {"1": {"name": "card id 1002","cantDelete": "false","id": "1002","script": "","dontSearch": "false","foregroundColor": "","rect": "0,0,400,400","backgroundColor": ""}},"name": "DatabaseDesignerAbstraction","id": "1002"},"7": {"script": "","foregroundColor": "","rect": "323,110,583,142","textSize": "","textStyle": "","customPropertySets": {"cREVGeneral": {"breakpointstates": "","breakpoints": "","breakpointconditions": "","scripteditorselection": "0","scalefactor": "1","scripteditorvscroll": "0"}},"resizable": "true","title": "","cantDelete": "false","cantModify": "false","shadow": "true","backgroundColor": "","textFont": "","cards": {"1": {"name": "card id 1002","cantDelete": "false","id": "1002","script": "","dontSearch": "false","foregroundColor": "","co