)\n   set the height of button \"dbdButtonBackground\" of newGroupLongID to (the height of newGroupLongID)\n   SetFontNames newGroupLongID\n   \n   // copy the navigation group\n   copy group \"dbdNavigationGroup\" of stack \"DatabaseDesignerToolsUI\" to newStackLongID\n   local newNavigationGroupLongID\n   put it into newNavigationGroupLongID\n   set the bottom of newNavigationGroupLongID to (the height of newStackLongID)\n   set the width of newNavigationGroupLongID to (the width of newStackLongID - the width of newGroupLongID)\n   set the left of newNavigationGroupLongID to 0\n   set the right of button \"dbdModeMenu\" of newNavigationGroupLongID to (the width of newStackLongID - the width of newGroupLongID - 10)\n   set the menuHistory of button \"dbdModeMenu\" of newNavigationGroupLongID to 2\n   disable group \"dbdNavigationControls\" of newNavigationGroupLongID\n   \n   // copy the edit group\n   copy group \"dbdEditGroup\" of stack \"DatabaseDesignerToolsUI\" to newStackLongID\n   local newEditGroupLongID\n   put it into newEditGroupLongID\n   set the topLeft of newEditGroupLongID to 0, 0\n   set the width of newEditGroupLongID to (the width of newStackLongID - the width of newGroupLongID)\n   set the height of newEditGroupLongID to (the height of newStackLongID - 20)\n   set the topLeft of button \"dbdEditGroupBackground\" of newEditGroupLongID to 0, 0\n   set the width of button \"dbdEditGroupBackground\" of newEditGroupLongID to (the width of newEditGroupLongID)\n   set the height of button \"dbdEditGroupBackground\" of newEditGroupLongID to (the height of newEditGroupLongID - 25)\n   if (the cMode of newStackLongID = \"edit\") then\n      set the backgroundColor of button \"dbdEditGroupBackground\" of newEditGroupLongID to 254,248,218\n   end if\n   \n   // set the custom properties\n   set the cDatabaseType of newStackLongID to databaseType\n   \n   // show the stack\n   show stack newStackLongID\n   unlock messages\n   reset the templateStack\nend CreateBlankDatabaseDesigner\n\n\ncommand DeleteCurrentRecord stackLongID\n   local recordSetID\n   put the cRecordSetID of stackLongID into recordSetID\n   local recordPosition\n   if (revCurrentRecordIsFirst(recordSetID)) then\n      put \"first\" into recordPosition\n   else if (revCurrentRecordIsLast(recordSetID)) then\n      put \"last\" into recordPosition\n   else\n      put revCurrentRecord(recordSetID) into recordPosition\n   end if\n   \n   select empty   \n   DBDelete the cDatabaseID of stackLongID, the cTableName of stackLongID, \"dbdID\", the cDBDID of stackLongID\n   SetNewRecordSetID stackLongID\n   NavigationMoveToRecord stackLongID, recordPosition\nend DeleteCurrentRecord\n\n\nlocal stackNumber  // this allows it to remember the number between calls to the function\nfunction GetNextUntitledStackName\n   if (stackNumber is EMPTY) then\n      put 1 into stackNumber\n   end if\n   repeat\n      if (there is a stack (\"Untitled\" && stackNumber)) OR (there is a folder (specialFolderPath(\"Documents\") & \"/\" & \"Untitled\" && stackNumber & \".DatabaseDesigner\")) then\n         add 1 to stackNumber\n      else\n         exit repeat\n      end if\n   end repeat\n   return \"Untitled\" && stackNumber\nend GetNextUntitledStackName\n\n\ncommand CreateDatabaseDesignerBundle stackName, databaseType, databaseInfo\n   local databaseID\n   if (databaseType = \"SQLite\") then\n      ask file empty with (specialFolderPath(\"Documents\") & \"/\" & stackName & \".DatabaseDesigner\") as sheet\n      \n      if (it <> EMPTY) AND (the result <> \"cancel\") then\n         lock screen\n         // create the bundle to store the LiveCode stack and the SQLite database\n         local bundlePath\n         put it into bundlePath\n         if (the platform = \"MacOS\") AND (bundlePath ends with \".DatabaseDesigner\" = FALSE) then\n            put \".DatabaseDesigner\" after bundlePath\n         end if\n         create folder bundlePath\n         \n         --         // set the stackName to the name of the bundle\n         --         put GetBundleNameFromBundlePath(bundlePath) into stackName\n         \n         // create the stack interface and save it in the bundle\n         CreateBlankDatabaseDesigner stackName, databaseType\n         save stack stackName as (bundlePath & \"/\" & stackName & \".dbd\") with newest format\n         --         set the cTableName of stack stackName to (the text of field \"SQLiteTableName\" of stack \"DatabaseDesignerNewFile\")\n         set the cTableName of stack stackName to (databaseInfo[\"tableName\"])\n         \n         put DBOpenSQLite(bundlePath & \"/\" & stackName & \".SQLite\") into databaseID\n         if (databaseID is not a number) then\n            return databaseID\n         end if\n         \n         local values\n         put \"dbdID INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL UNIQUE\" into values[1]\n         DBTableCreate databaseID, the cTableName of stack stackName, values\n         local theResult\n         put the result into theResult\n         if (theResult contains \"exists\") then\n            RevCloseDatabase databaseID\n            --            answer theResult\n            return theResult\n         end if\n         \n         set the cDatabaseID of stack stackName to databaseID\n         set the cDatabaseType of stack stackName to databaseType\n      end if\n      \n   else if (databaseType = \"MySQL\") then\n      --      local theHostAddress\n      --      put the text of field \"MySQLAddress\" of stack \"DatabaseDesignerNewFile\" into theHostAddress\n      --      local theDatabaseName\n      --      put the text of field \"MySQLDatabase\" of stack \"DatabaseDesignerNewFile\" into theDatabaseName\n      --      local tableName\n      --      put the text of field \"MySQLTableName\" of stack \"DatabaseDesignerNewFile\" into tableName\n      --      local theUserName\n      --      put the text of field \"MySQLUserName\" of stack \"DatabaseDesignerNewFile\" into theUserName\n      --      local thePassword\n      --      put the text of field \"MySQLPassword\" of stack \"DatabaseDesignerNewFile\" into thePassword\n      --      local useSSL\n      --      put the hilite of button \"MySQLUseSSL\" of stack \"DatabaseDesignerNewFile\" into useSSL\n      --      put revOpenDatabase(\"mysql\", theHostAddress, theDatabaseName, theUserName, thePassword, useSSL, , 0, TRUE) into databaseID\n      put revOpenDatabase(\"mysql\", databaseInfo[\"address\"], databaseInfo[\"database\"], databaseInfo[\"userName\"], databaseInfo[\"password\"], databaseInfo[\"useSSL\"], , 0, TRUE) into databaseID\n      if (databaseID is not a number) then\n         return databaseID\n      end if\n      // create the table\n      put \"dbdID INTEGER PRIMARY KEY AUTO_INCREMENT NOT NULL UNIQUE\" into values[1]\n      DBTableCreate databaseID, databaseInfo[\"tableName\"], values\n      put the result into theResult\n      if (theResult contains \"exists\") then\n         RevCloseDatabase databaseID\n         return theResult\n      end if\n      \n      ask file empty with (specialFolderPath(\"Documents\") & \"/\" & stackName & \".DatabaseDesigner\") as sheet\n      if (it <> EMPTY) AND (the result <> \"cancel\") then\n         lock screen\n         // create the bundle to store the LiveCode stack\n         put it into bundlePath\n         if (the platform = \"MacOS\") AND (bundlePath ends with \".DatabaseDesigner\" = FALSE) then\n            put \".DatabaseDesigner\" after bundlePath\n         end if\n         create folder bundlePath\n         \n         --            // set the stackName to the name of the bundle\n         --            put GetBundleNameFromBundlePath(bundlePath) into stackName\n         \n         // create the stack interface and save it in the bundle\n         CreateBlankDatabaseDesigner stackName, databaseType\n         save stack stackName as (bundlePath & \"/\" & stackName & \".dbd\") with newest format\n         \n         set the cHostAddress of stack stackName to databaseInfo[\"address\"]\n         set the cDatabaseName of stack stackName to databaseInfo[\"database\"]\n         set the cUserName of stack stackName to databaseInfo[\"userName\"]\n         --         set the cPassword of stack stackName to thePassword\n         set the cUseSSL of stack stackName to databaseInfo[\"useSSL\"]\n         set the cTableName of stack stackName to databaseInfo[\"tableName\"]\n         set the cDatabaseID of stack stackName to databaseID\n         set the cDatabaseType of stack stackName to databaseType\n      end if\n      \n      \n   else if (databaseType = \"PostgreSQL\") then\n      put revOpenDatabase(\"postgresql\", databaseInfo[\"address\"], databaseInfo[\"database\"], databaseInfo[\"userName\"], databaseInfo[\"password\"], \"sslmode=prefer\") into databaseID\n      if (databaseID is not a number) then\n         return databaseID\n      end if\n      // create the table\n      put \"dbdID BIGSERIAL\" into values[1]\n      DBTableCreate databaseID, databaseInfo[\"tableName\"], values\n      put the result into theResult\n      if (theResult contains \"exists\") then\n         RevCloseDatabase databaseID\n         return theResult\n      end if\n      \n      ask file empty with (specialFolderPath(\"Documents\") & \"/\" & stackName & \".DatabaseDesigner\") as sheet\n      if (it <> EMPTY) AND (the result <> \"cancel\") then\n         lock screen\n         // create the bundle to store the LiveCode stack\n         put it into bundlePath\n         if (the platform = \"MacOS\") AND (bundlePath ends with \".DatabaseDesigner\" = FALSE) then\n            put \".DatabaseDesigner\" after bundlePath\n         end if\n         create folder bundlePath\n         \n         --            // set the stackName to the name of the bundle\n         --            put GetBundleNameFromBundlePath(bundlePath) into stackName\n         \n         // create the stack interface and save it in the bundle\n         CreateBlankDatabaseDesigner stackName, databaseType\n         save stack stackName as (bundlePath & \"/\" & stackName & \".dbd\") with newest format\n         \n         set the cHostAddress of stack stackName to databaseInfo[\"address\"]\n         set the cDatabaseName of stack stackName to databaseInfo[\"database\"]\n         set the cUserName of stack stackName to databaseInfo[\"userName\"]\n         --         set the cPassword of stack stackName to thePassword\n         set the cUseSSL of stack stackName to databaseInfo[\"useSSL\"]\n         set the cTableName of stack stackName to databaseInfo[\"tableName\"]\n         set the cDatabaseID of stack stackName to databaseID\n         set the cDatabaseType of stack stackName to databaseType\n      end if\n   end if\n   \n   \n   \n   \n   \n   --      // open the SQLite database and save it in the bundle\n   --      local databaseID\n   --      if (databaseType = \"SQLite\") then\n   --         set the cTableName of stack stackName to (the text of field \"SQLiteTableName\" of stack \"DatabaseDesignerNewFile\")\n   --         put DBOpenSQLite(bundlePath & \"/\" & stackName & \".SQLite\") into databaseID\n   --      else if (databaseType = \"MySQL\") then\n   --         local theHostAddress\n   --         put the text of field \"MySQLAddress\" of stack \"DatabaseDesignerNewFile\" into theHostAddress\n   --         set the cHostAddress of stack stackName to theHostAddress\n   --         local theDatabaseName\n   --         put the text of field \"MySQLDatabase\" of stack \"DatabaseDesignerNewFile\" into theDatabaseName\n   --         set the cDatabaseName of stack stackName to theDatabaseName\n   --         local theUserName\n   --         put the text of field \"MySQLUserName\" of stack \"DatabaseDesignerNewFile\" into theUserName\n   --         set the cUserName of stack stackName to theUserName\n   --         local thePassword\n   --         put the text of field \"MySQLPassword\" of stack \"DatabaseDesignerNewFile\" into thePassword\n   --         set the cPassword of stack stackName to thePassword\n   --         local useSSL\n   --         put the hilite of button \"MySQLUseSSL\" of stack \"DatabaseDesignerNewFile\" into useSSL\n   --         set the cUseSSL of stack stackName to useSSL\n   --         set the cTableName of stack stackName to (the text of field \"MySQLTableName\" of stack \"DatabaseDesignerNewFile\")\n   --         put revOpenDatabase(\"mysql\", theHostAddress, theDatabaseName, theUserName, thePassword, useSSL, , 0, TRUE) into databaseID\n   --         if (databaseID is not a number) then\n   --            close stack stackName\n   --            answer databaseID\n   --            exit CreateDatabaseDesignerBundle\n   --         end if\n   --      end if\n   --      set the cDatabaseID of stack stackName to databaseID\n   --      set the cDatabaseType of stack stackName to databaseType\n   --      --      set the cTableName of stack stackName to (GetTableNameFromBundleName(stackName))\n   \n   --      // create the table\n   --      local autoIncrement\n   --      if (databaseType = \"SQLite\") then\n   --         put \"AUTOINCREMENT\" into autoIncrement\n   --      else if (databaseType = \"MySQL\") then\n   --         put \"AUTO_INCREMENT\" into autoIncrement\n   --      end if\n   --      local values\n   --      put \"dbdID INTEGER PRIMARY KEY \" & autoIncrement & \" NOT NULL UNIQUE\" into values[1]\n   --      DBTableCreate databaseID, the cTableName of stack stackName, values\n   --      local theResult\n   --      put the result into theResult\n   --      if (theResult contains \"exists\") then\n   --         close stack stackName\n   --         answer theResult\n   --         return theResult\n   --      end if\n   --   end if\nend CreateDatabaseDesignerBundle\n   \n   \n   // Use the arrow keys to move the selected object, does not work in the IDE\non RawKeyDown key\n   if (the environment <> \"development\") then\n      if (key = 65361) then\n         set the left of the selectedObject to (the left of the selectedObject - 1)\n      else if (key = 65362) then\n         set the top of the selectedObject to (the top of the selectedObject - 1)\n      else if (key = 65363) then\n         set the left of the selectedObject to (the left of the selectedObject + 1)\n      else if (key = 65364) then\n         set the top of the selectedObject to (the top of the selectedObject + 1)\n      end if\n   end if\n   pass RawKeyDown\nend RawKeyDown\n\n\n// Dispays an open file dialog to select the database designer file/bundle\ncommand RequestToOpenDatabaseDesigner\n   if (the platform = \"MacOS\") then\n      answer file \"Select a Database Designer file:\" with specialFolderPath(\"Documents\") with type \"Database Designer File|DatabaseDesigner|dbd\" as sheet\n   else\n      answer file \"Select a Database Designer file:\" with specialFolderPath(\"Documents\") with type \"Database Designer File|dbd|dbd\" as sheet\n   end if\n   if (it <> EMPTY) AND (the result <> \"cancel\") then\n      if (the platform is \"MacOS\") then\n         OpenDatabaseDesignerBundle it\n      else\n         OpenDatabaseDesignerFile it\n      end if\n   end if\nend RequestToOpenDatabaseDesigner\n\n\ncommand LoadStackFileFromBundlePath bundlePath\n   local oldDefaultFolder\n   put the defaultFolder into oldDefaultFolder\n   set the defaultFolder to bundlePath\n   local theFiles\n   put the files into theFiles\n   local stackName\n   repeat for each line theFile in theFiles\n      if (character -3 to -1 of theFile = \"dbd\") then\n         put theFile into stackName\n         exit repeat\n      end if\n   end repeat\n   lock screen\n   go stack (bundlePath & \"/\" & stackName)\n   local longStackID\n   put the long id of the topStack into longStackID\n   set the visible of the topStack to FALSE\n   set the defaultFolder to oldDefaultFolder\n   return longStackID\nend LoadStackFileFromBundlePath\n\n\ncommand NavigationMoveToRecord stackLongID, recordPosition\n   if (the selectedField <> EMPTY) then\n      local selectedFieldObject\n      put the selectedField into selectedFieldObject\n      select empty\n      if (selectedFieldObject <> EMPTY) then\n         select text of selectedFieldObject\n      end if\n   end if\n   \n   if (recordPosition = \"first\") then\n      DBMoveToFirstRecord (the cRecordSetID of stackLongID)\n   else if (recordPosition = \"previous\") then\n      DBMoveToPreviousRecord (the cRecordSetID of stackLongID)\n   else if (recordPosition = \"next\") then\n      DBMoveToNextRecord (the cRecordSetID of stackLongID)\n   else if (recordPosition = \"last\") then\n      DBMoveToLastRecord (the cRecordSetID of stackLongID)\n   else if (recordPosition is a number) then\n      DBMoveToRecord (the cRecordSetID of stackLongID), recordPosition\n   end if\n   \n   set the cDBDID of stackLongID to (revDatabaseColumnNamed(the cRecordSetID of stackLongID, \"dbdID\"))\n   UpdateUserFieldControlContent stackLongID  // DatabaseDesignerLibrary\n   ToggleUserFieldTraversalOn stackLongID  // DatabaseDesignerLibrary\n   UpdateTheCurrentRecordUI stackLongID  // DatabaseDesignerLibrary\n   UpdateTheNumberOfRecordsUI stackLongID  // DatabaseDesignerLibrary\nend NavigationMoveToRecord\n\n\ncommand NewFile databaseType, stackName\n   --   local stackName\n   --   put GetNextUntitledStackName() into stackName\n   \n   --   if (databaseType = \"SQLite\") then\n   --      put (the text of field \"SQLiteTableName\" of stack \"DatabaseDesignerNewFile\")  into stackName\n   --   else if (databaseType = \"MySQL\") then\n   --      put (the text of field \"MySQLTableName\" of stack \"DatabaseDesignerNewFile\")  into stackName\n   --   else if (databaseType = \"PostgreSQL\") then\n   --      put (the text of field \"MySQLTableName\" of stack \"DatabaseDesignerNewFile\")  into stackName\n   --   end if\n   \n   --   CreateDatabaseDesignerBundle stackName, databaseType  // does nothing if there is an error\n   --   if (the result <> EMPTY) then\n   --      return the result\n   --   end if\nend NewFile\n\n\ncommand OpenDatabaseDesignerFile stackPath\n   try\n      local bundlePath\n      set the itemDelimiter to \"/\"\n      put (item 1 to -2 of stackPath) into bundlePath\n      \n      OpenDatabaseDesignerBundle bundlePath\n   end try\nend OpenDatabaseDesignerFile\n\n\ncommand OpenDatabaseDesignerBundle bundlePath\n   lock screen\n   \n   local bundleExtension\n   set the itemDelimiter to \".\"\n   put the last item of bundlePath into bundleExtension\n   \n   if (bundlePath <> EMPTY) then //AND (bundleExtension = \"DatabaseDesigner\") then\n      LoadStackFileFromBundlePath bundlePath\n      \n      local longStackID\n      put the result into longStackID\n      \n      local databaseID\n      switch the cDatabaseType of longStackID //the topStack\n         case \"SQLite\"\n            local databaseName\n            put GetDatabaseNameFromBundlePath(bundlePath) into databaseName\n            put DBOpenSQLite(bundlePath & \"/\" & databaseName) into databaseID\n            break\n         case \"MySQL\"\n            local theHostAddress\n            put the cHostAddress of longStackID into theHostAddress\n            local theDatabaseName\n            put the cDatabaseName of longStackID into theDatabaseName\n            local theUserName\n            put the cUserName of longStackID into theUserName\n            --            local thePassword\n            --            put the cPassword of the topStack into thePassword\n            if (the cPassword of the topStack is not EMPTY) then\n               set the cPassword of the topStack to EMPTY\n            end if\n            local useSSL\n            put the cUseSSL of longStackID into useSSL\n            \n            ask password \"Please enter the database password:\" titled \"Enter Password\" as sheet\n            if (the result = \"Cancel\") then\n               close the topStack\n               exit OpenDatabaseDesignerBundle\n            end if\n            local thePassword\n            put it into thePassword\n            \n            put revOpenDatabase(\"mysql\", theHostAddress, theDatabaseName, theUserName, thePassword, useSSL, , 0, TRUE) into databaseID\n            break\n         case \"PostgreSQL\"\n            ask password \"Please enter the database password:\" titled \"Enter Password\" as sheet\n            if (the result = \"Cancel\") then\n               close the topStack\n               exit OpenDatabaseDesignerBundle\n            end if\n            put revOpenDatabase(\"postgresql\", the cHostAddress of longStackID, \\\n                  the cDatabaseName of longStackID, the cUserName of longStackID, it, \"sslmode=prefer\") into databaseID\n            break\n      end switch\n      \n      set the title of longStackID to GetStackTitleFromBundlePath(bundlePath) && \"[\" & the cDatabaseType of longStackID & \"]\" \n      set the cDatabaseID of longStackID to databaseID\n      \n      local tableName\n      put the cTableName of longStackID into tableName\n      if (tableName is EMPTY) then\n         put \"dbdMainTable\" into tableName\n      end if\n      --      put GetTableName(databaseID) into tableName\n      --      set the cTableName of the topStack to tableName\n      \n      local recordSetID\n      put DBRecordSetCreate(databaseID, \"SELECT * FROM\" && tableName) into recordSetID\n      set the cRecordSetID of longStackID to recordSetID\n      \n      NavigationMoveToRecord the long id of longStackID, 0\n      \n      set the menuHistory of button \"dbdModeMenu\" of longStackID to 1  // sets the mode popup to Browse\n      set the cMode of longStackID to \"browse\"\n      enable group \"dbdNavigationControls\" of longStackID\n      \n      local newGroupLongID\n      if (the cVersion of group \"dbdTools\" of longStackID < 4) then\n         delete group \"dbdTools\" of longStackID\n         copy group \"dbdTools\" of stack \"DatabaseDesignerToolsUI\" to longStackID\n         put it into newGroupLongID\n         set the left of newGroupLongID to (the right of group \"dbdEditGroup\" of longStackID)\n         set the height of newGroupLongID to (the height of longStackID + 2)\n         set the height of button \"dbdButtonBackground\" of newGroupLongID to (the height of newGroupLongID)\n      end if\n      if (the cVersion of group \"dbdNavigationGroup\" of longStackID < 4) then\n         delete group \"dbdNavigationGroup\" of longStackID\n         copy group \"dbdNavigationGroup\" of stack \"DatabaseDesignerToolsUI\" to longStackID\n         put it into newGroupLongID\n         set the left of newGroupLongID to 0\n         set the width of newGroupLongID to (the width of longStackID)\n         set the bottom of newGroupLongID to (the height of longStackID)\n      end if\n      SetFontNames long id of group \"dbdTools\" of longStackID\n      set the visible of longStackID to TRUE\n   end if\nend OpenDatabaseDesignerBundle\n\n\nfunction GetTableName databaseID\n   --   local tableNames\n   --   put revDatabaseTableNames(databaseID) into tableNames\n   --   repeat for each line tableName in tableNames\n   --      if (tableName <> \"sqlite_sequence\") then\n   --         return tableName\n   --         exit repeat\n   --      end if\n   --   end repeat\n   --   // should naver get here but if it does oh noes\n   return \"dbdMainTable\"\nend GetTableName\n\n\nfunction GetStackFileNameFromBundlePath bundlePath\n   --   local oldDefaultFolder\n   --   put the defaultFolder into oldDefaultFolder\n   --   set the defaultFolder to bundlePath\n   --   local theFiles\n   --   put the files into theFiles\n   --   local stackName\n   --   repeat for each line theFile in theFiles\n   --      if (character -3 to -1 of theFile = \"dbd\") then\n   --         put theFile into stackName\n   --         exit repeat\n   --      end if\n   --   end repeat\n   --   set the defaultFolder to oldDefaultFolder\n   --   return stackName\nend GetStackFileNameFromBundlePath\n\n\nfunction GetStackTitleFromBundlePath bundlePath\n   local stackTitle\n   set the itemDelimiter to \"/\"\n   put item -1 of bundlePath into stackTitle\n   replace \".DatabaseDesigner\" with EMPTY in stackTitle\n   return stackTitle\nend GetStackTitleFromBundlePath\n\n\nfunction GetBundleNameFromBundlePath bundlePath\n   local bundleName\n   set the itemDelimiter to \"/\"\n   put the last item of bundlePath into bundleName\n   --   set the itemDelimiter to \".\"\n   --   delete the last item of bundleName\n   replace \".DatabaseDesigner\" with EMPTY in bundleName\n   return bundleName\nend GetBundleNameFromBundlePath\n\n\nfunction GetDatabaseNameFromBundlePath bundlePath\n   local oldDefaultFolder\n   put the defaultFolder into oldDefaultFolder\n   set the defaultFolder to bundlePath\n   local theFiles\n   put the files into theFiles\n   local databaseName\n   repeat for each line theFile in theFiles\n      if (character -6 to -1 of theFile = \"SQLite\") then\n         put theFile into databaseName\n         exit repeat\n      end if\n   end repeat\n   set the defaultFolder to oldDefaultFolder\n   return databaseName\nend GetDatabaseNameFromBundlePath\n\n\nfunction GetDatabaseNameFromStackPath stackPath\n   local oldDefaultFolder\n   put the defaultFolder into oldDefaultFolder\n   set the itemDelimiter to \"/\"\n   set the defaultFolder to (item 1 to -2 of stackPath)\n   local theFiles\n   put the files into theFiles\n   local databaseName\n   repeat for each line theFile in theFiles\n      if (character -7 to -1 of theFile = \".SQLite\") then\n         put theFile into databaseName\n         exit repeat\n      end if\n   end repeat\n   set the defaultFolder to oldDefaultFolder\n   return databaseName\nend GetDatabaseNameFromStackPath\n   \n   \ncommand SaveStack stackLongID\n   save stackLongID\nend SaveStack\n\n\nfunction GetTableNameFromBundleName bundleName\n   --   if (char 1 of bundleName is a number) then\n   --      put \"t\" before bundleName\n   --   end if\n   --   replace SPACE with EMPTY in bundleName\n   --   if (the length of bundleName > 32) then\n   --      return char 1 to 32 of bundleName\n   --   else\n   --      return bundleName\n   --   end if\n   return \"dbdMainTable\"\nend GetTableNameFromBundleName\n\n\ncommand SelectedObjectChangedToCheckbox\n   lock screen\n   set the enabled of field \"dbdNameField\" to TRUE\n   set the enabled of field \"dbdTextField\" to TRUE\n   set the text of field \"dbdNameField\" to (the short name of the selectedObject)\n   set the text of field \"dbdTextField\" to (the label of the selectedObject)\n   set the menuHistory of button \"dbdTypeField\" to (the cTypeMenuHistory of the selectedObject)\n   set the enabled of button \"dbdTypeField\" to FALSE\n   set the enabled of button \"dbdUnique\" to FALSE\n   set the enabled of button \"dbdNotNull\" to FALSE\n   enable button \"dbdFontField\"\n   enable field \"dbdSizeField\"\n   enable button \"dbdColourButton\"\n   --   set the text of button \"dbdFontField\" to (the effective TextFont of the selectedObject)\n   set the MenuHistory of button \"dbdFontField\" to (lineOffset(the effective TextFont of the selectedObject, the text of button \"dbdFontField\"))\n   set the text of field \"dbdSizeField\" to (the effective TextSize of the selectedObject)\n   set the backgroundColor of button \"dbdColourButton\" to (the effective foregroundColor of the selectedObject)\n   enable button \"dbdAlignField\"\n   set the MenuHistory of button \"dbdAlignField\" to (lineOffset(the effective TextAlign of the selectedObject, the text of button \"dbdAlignField\"))\n   enable button \"dbdStyleField\"\n   set the MenuHistory of button \"dbdStyleField\" to (lineOffset(the effective TextStyle of the selectedObject, the text of button \"dbdStyleField\"))\nend SelectedObjectChangedToCheckbox\n\n\ncommand SelectedObjectChangedToField\n   lock screen\n   set the enabled of field \"dbdNameField\" to TRUE\n   set the enabled of field \"dbdTextField\" to FALSE\n   set the text of field \"dbdNameField\" to (the short name of the selectedObject)\n   set the text of field \"dbdTextField\" to EMPTY\n   set the menuHistory of button \"dbdTypeField\" to (the cTypeMenuHistory of the selectedObject)\n   set the enabled of button \"dbdTypeField\" to TRUE\n   set the enabled of button \"dbdUnique\" to TRUE\n   set the enabled of button \"dbdNotNull\" to TRUE\n   enable button \"dbdFontField\"\n   enable field \"dbdSizeField\"\n   enable button \"dbdColourButton\"\n   --   set the text of button \"dbdFontField\" to (the effective TextFont of the selectedObject)\n   set the MenuHistory of button \"dbdFontField\" to (lineOffset(the effective TextFont of the selectedObject, the text of button \"dbdFontField\"))\n   set the text of field \"dbdSizeField\" to (the effective TextSize of the selectedObject)\n   set the backgroundColor of button \"dbdColourButton\" to (the effective foregroundColor of the selectedObject)\n   enable button \"dbdAlignField\"\n   set the MenuHistory of button \"dbdAlignField\" to (lineOffset(the effective TextAlign of the selectedObject, the text of button \"dbdAlignField\"))\n   enable button \"dbdStyleField\"\n   set the MenuHistory of button \"dbdStyleField\" to (lineOffset(the effective TextStyle of the selectedObject, the text of button \"dbdStyleField\"))\nend SelectedObjectChangedToField\n\n\ncommand SelectedObjectChangedToLabel\n   lock screen\n   set the enabled of field \"dbdNameField\" to TRUE\n   set the enabled of field \"dbdTextField\" to TRUE\n   set the text of field \"dbdNameField\" to (the short name of the selectedObject)\n   set the text of field \"dbdTextField\" to (the text of the selectedObject)\n   set the menuHistory of button \"dbdTypeField\" to (the cTypeMenuHistory of the selectedObject)\n   enable button \"dbdFontField\"\n   enable field \"dbdSizeField\"\n   enable button \"dbdColourButton\"\n   set the MenuHistory of button \"dbdFontField\" to (lineOffset(the effective TextFont of the selectedObject, the text of button \"dbdFontField\"))\n   set the text of field \"dbdSizeField\" to (the effective TextSize of the selectedObject)\n   set the backgroundColor of button \"dbdColourButton\" to (the effective foregroundColor of the selectedObject)\n   enable button \"dbdAlignField\"\n   set the MenuHistory of button \"dbdAlignField\" to (lineOffset(the effective TextAlign of the selectedObject, the text of button \"dbdAlignField\"))\n   enable button \"dbdStyleField\"\n   set the MenuHistory of button \"dbdStyleField\" to (lineOffset(the effective TextStyle of the selectedObject, the text of button \"dbdStyleField\"))\nend SelectedObjectChangedToLabel=\n\n\n\ncommand SelectedObjectChangedToNoObject\n   lock screen\n   set the enabled of field \"dbdNameField\" to FALSE\n   set the text of field \"dbdNameField\" to EMPTY\n   set the enabled of field \"dbdTextField\" to FALSE\n   set the text of field \"dbdTextField\" to EMPTY\n   set the menuHistory of button \"dbdTypeField\" to 1\n   set the enabled of button \"dbdTypeField\" to FALSE\n   set the enabled of button \"dbdAutoIncrement\" to FALSE\n   set the enabled of button \"dbdUnique\" to FALSE\n   set the enabled of button \"dbdNotNull\" to FALSE\n   disable button \"dbdFontField\"\n   disable field \"dbdSizeField\"\n   disable button \"dbdColourButton\"\n   --   set the text of button \"dbdFontField\" to \"(Default)\"\n   set the text of field \"dbdSizeField\" to 13\n   set the backgroundColor of button \"dbdColourButton\" to \"Black\"\n   disable button \"dbdStyleField\"\n   disable button \"dbdAlignField\"\nend SelectedObjectChangedToNoObject\n\n\ncommand SelectedObjectChangedToPicture\n   lock screen\n   set the enabled of field \"dbdNameField\" to TRUE\n   set the enabled of field \"dbdTextField\" to FALSE\n   set the text of field \"dbdNameField\" to (the short name of the selectedObject)\n   set the text of field \"dbdTextField\" to EMPTY\n   set the enabled of button \"dbdTypeField\" to FALSE\n   set the enabled of button \"dbdUnique\" to FALSE\n   set the enabled of button \"dbdNotNull\" to FALSE\n   disable button \"dbdFontField\"\n   disable field \"dbdSizeField\"\n   disable button \"dbdColourButton\"\n   set the text of button \"dbdFontField\" to \"(Default)\"\n   set the text of field \"dbdSizeField\" to 13\n   set the backgroundColor of button \"dbdColourButton\" to \"Black\"\n   disable button \"dbdStyleField\"\n   disable button \"dbdAlignField\"\nend SelectedObjectChangedToPicture\n\n\ncommand SelectedObjectChangedToScrollingField\n   lock screen\n   set the enabled of field \"dbdNameField\" to TRUE\n   set the text of field \"dbdNameField\" to (the short name of the selectedObject)\n   set the enabled of field \"dbdTextField\" to FALSE\n   set the text of field \"dbdTextField\" to EMPTY\n   set the menuHistory of button \"dbdTypeField\" to (the cTypeMenuHistory of the selectedObject)\n   set the enabled of button \"dbdTypeField\" to TRUE\n   set the enabled of button \"dbdUnique\" to TRUE\n   set the enabled of button \"dbdNotNull\" to TRUE\n   enable button \"dbdFontField\"\n   enable field \"dbdSizeField\"\n   enable button \"dbdColourButton\"\n   --   set the text of button \"dbdFontField\" to (the effective TextFont of the selectedObject)\n   set the MenuHistory of button \"dbdFontField\" to (lineOffset(the effective TextFont of the selectedObject, the text of button \"dbdFontField\"))\n   set the text of field \"dbdSizeField\" to (the effective TextSize of the selectedObject)\n   set the backgroundColor of button \"dbdColourButton\" to (the effective foregroundColor of the selectedObject)\n   enable button \"dbdAlignField\"\n   set the MenuHistory of button \"dbdAlignField\" to (lineOffset(the effective TextAlign of the selectedObject, the text of button \"dbdAlignField\"))\n   enable button \"dbdStyleField\"\n   set the MenuHistory of button \"dbdStyleField\" to (lineOffset(the effective TextStyle of the selectedObject, the text of button \"dbdStyleField\"))\nend SelectedObjectChangedToScrollingField\n\n\ncommand SetFontNames groupID\n   --   if (the text of me is EMPTY) then\n   local tFontNames\n   put the fontNames into tFontNames\n   sort tFontNames\n   --   replace \"(\" with \"((\" in tFontNames\n   filter tFontNames without \"(*\"\n   set the text of button \"dbdFontField\" of groupID to tFontNames\n   --end if\nend SetFontNames\n\n\ncommand SetNewRecordSetID stackLongID\n   DBRecordSetClose the cRecordSetID of stackLongID\n   local recordSetID\n   put DBRecordSetCreate(the cDatabaseID of stackLongID, \"SELECT * FROM\" && the cTableName of stackLongID) into recordSetID\n   set the cRecordSetID of stackLongID to recordSetID\nend SetNewRecordSetID\n\n\ncommand ToggleUserCheckboxAutoHilite stackLongID\n   local databaseID\n   put the cDatabaseID of stackLongID into databaseID\n   local recordSetID\n   put the cRecordSetID of stackLongID into recordSetID\n   local recordSetCount\n   put DBRecordSetCount(recordSetID) into recordSetCount\n   local numberOfControls\n   put the number of controls of stackLongID into numberOfControls  \n   if (recordSetID is a number) then\n      repeat with i = 1 to numberOfControls\n         if (char 1 to 3 of the short name of control i <> \"dbd\") then\n            if (databaseID <> EMPTY) AND (recordSetID <> EMPTY) AND (the cControlType of control i = \"checkbox\") then\n               set the autoHilite of control i to ((recordSetCount > 0) AND (the cMode of stackLongID = \"browse\"))\n            end if\n         end if\n      end repeat\n   end if\nend ToggleUserCheckboxAutoHilite\n\n\ncommand ToggleUserFieldTraversalOn stackLongID\n   local databaseID\n   put the cDatabaseID of stackLongID into databaseID\n   local recordSetID\n   put the cRecordSetID of stackLongID into recordSetID\n   local recordSetCount\n   put DBRecordSetCount(recordSetID) into recordSetCount\n   local numberOfControls\n   put the number of controls of stackLongID into numberOfControls  \n   if (recordSetID is a number) then\n      repeat with i = 1 to numberOfControls\n         if (char 1 to 3 of the short name of control i <> \"dbd\") then\n            if (databaseID <> EMPTY) AND (recordSetID <> EMPTY) AND (the cControlType of control i <> \"label\") then\n               if (the cControlType of control i = \"picture\") then\n                  set the lockLoc of control i to (the cMode of stackLongID = \"browse\")\n               else\n                  set the traversalOn of control i to (recordSetCount > 0)\n               end if\n            end if\n         end if\n      end repeat\n   end if\nend ToggleUserFieldTraversalOn\n\n\ncommand UpdateTheNumberOfRecordsUI stackLongID\n   local recordSetCount\n   put DBRecordSetCount(the cRecordSetID of stackLongID) into recordSetCount\n   set the text of field \"dbdNumberOfRecords\" of stackLongID to recordSetCount\nend UpdateTheNumberOfRecordsUI\n\n\ncommand UpdateUserFieldControlContent stackLongID\n   local databaseID\n   put the cDatabaseID of stackLongID into databaseID\n   local recordSetID\n   put the cRecordSetID of stackLongID into recordSetID\n   local numberOfControls\n   put the number of controls of stackLongID into numberOfControls  \n   if (recordSetID is a number) then\n      repeat with i = 1 to numberOfControls\n         if (char 1 to 3 of the short name of control i <> \"dbd\") then\n            if (databaseID <> EMPTY) AND (recordSetID <> EMPTY) AND (the cControlType of control i <> \"label\") then\n               if (the cControlType of control i = \"picture\") then\n                  local blobData\n                  get revDatabaseColumnNamed(recordSetID, the cName of control i, \"blobData\")\n                  set the text of control i to blobData\n               else if (the cControlType of control i = \"checkbox\") then\n                  local hiliteStatus\n                  put (revDatabaseColumnNamed(recordSetID, the cName of control i)) into hiliteStatus\n                  --                  if (hiliteStatus = EMPTY) then put FALSE into hiliteStatus\n                  if (the cDatabaseType of stackLongID = \"SQLite\") then\n                     if (hiliteStatus = EMPTY) then put FALSE into hiliteStatus\n                     set the hilite of control i to hiliteStatus\n                  else if (the cDatabaseType of stackLongID = \"MySQL\") then\n                     if (hiliteStatus = EMPTY) then put 0 into hiliteStatus\n                     set the hilite of control i to (hiliteStatus = 1)\n                  end if\n               else\n                  set the text of control i to TextDecode(revDatabaseColumnNamed(recordSetID, the cName of control i), \"UTF8\")\n               end if\n            end if\n         end if\n      end repeat\n   end if\nend UpdateUserFieldControlContent\n\n\ncommand UpdateTheCurrentRecordUI stackLongID\n   lock messages\n   if (revNumberOfRecords(the cRecordSetID of stackLongID) = 0) then\n      set the text of field \"dbdCurrentRecord\" of stackLongID to 0\n   else\n      set the text of field \"dbdCurrentRecord\" of stackLongID to ((revCurrentRecord(the cRecordSetID of stackLongID)) + 1)\n   end if\n   unlock messages\nend UpdateTheCurrentRecordUI\n\n\ncommand UpdateDataInDatabase stackLongID, fieldShortName, fieldText\n   DBUpdate (the cDatabaseID of stackLongID), (the cTableName of stackLongID), \\\n         fieldShortName, TextEncode(fieldText, \"UTF8\"), \"dbdID\", (the cDBDID of stackLongID)\nend UpdateDataInDatabase\n\n\ncommand UpdatePictureDataInDatabase stackLongID, imageShortName, imageText\n   DBUpdateBLOB (the cDatabaseID of stackLongID), (the cTableName of stackLongID), \\\n         imageShortName, imageText, \"dbdID\", (the cDBDID of stackLongID)\nend UpdatePictureDataInDatabase\n","foregroundColor": "","rect": "446,114,846,514","textSize": "","textStyle": "","customPropertySets": {"cREVGeneral": {"breakpointstates": "","breakpoints": "","breakpointconditions": "","scripteditorselection": "12882","scripteditorvscroll": "5055","scalefactor": "1"}},"resizable": "true","title": "","cantDelete": "false","cantModify": "false","shadow": "true","backgroundColor": "","textFont": "","cards": {"1": {"name": "card id 1002","cantDelete": "false","id": "1002","script": "","dontSearch": "false","foregroundColor": "","rect": "0,0,400,400","backgroundColor": ""}},"name": "DatabaseDesignerLibrary","id": "1002"},"3": {"script": "on SelectedObjectChanged\n   lock screen\n   lock messages\n   \n   if (the cMode of this stack = \"edit\") then\n      // stops multiple selections from happening\n      if (the shiftKey is down) AND (the selectedObject is not EMPTY) then\n         select the selectedObject\n      end if\n      \n      // update the inspector\n      SelectedObjectChangedToNoObject  // DatabaseDesignerLibrary\n      \n      // only update the inspector if an object is selected\n      if (the selectedObject is not EMPTY) AND (the selected of the selectedObject is TRUE) then\n         set the cSelectedObject of this stack to (the selectedObject)\n         switch (the cControlType of the selectedObject)\n            case \"checkbox\"\n               SelectedObjectChangedToCheckbox  // DatabaseDesignerLibrary\n               break\n            case \"label\"\n               SelectedObjectChangedToLabel  // in database designer library\n               break\n            case \"field\"\n               SelectedObjectChangedToField  // in database designer library\n               break\n            case \"scrollingField\"\n               SelectedObjectChangedToScrollingField  // DatabaseDesignerLibrary\n               break\n            case \"picture\"\n               SelectedObjectChangedToPicture  // DatabaseDesignerLibrary\n               break\n         end switch\n      end if\n   end if\n   pass SelectedObjectChanged\nend SelectedObjectChanged\n\n\non CloseStackRequest   \n   CloseStackRequestHandler\n   pass closeStackRequest\nend CloseStackRequest\n\n\ncommand CloseStackRequestHandler\n   // this will save any changes made to the field/scrolling field object\n   local numberOfControls\n   put the number of controls into numberOfControls\n   repeat with i = 1 to numberOfControls\n      if (char 1 to 3 of the short name of control i <> \"dbd\") AND (the cControlType of control i <> \"label\") AND (the cControlType of control i <> \"picture\") AND (the cControlType of control i <> \"checkbox\") then\n         dispatch \"UpdateData\" to control i\n      end if\n   end repeat\n   \n   LockPictureLocation  // DatabaseDesignerBehaviour\n   \n   // close the record set and database connection\n   if (the cRecordSetID of this stack <> EMPTY) then DBRecordSetClose the cRecordSetID of this stack\n   if (the cDatabaseID of this stack <> EMPTY) then DBClose the cDatabaseID of this stack\n   \n   // empty out the stack custom properties\n   set the cDBDID of this stack to EMPTY\n   set the cDatabaseID of this stack to EMPTY\n   set the cMode of this stack to EMPTY\n   set the cRecordSetID of this stack to EMPTY\n   set the cSelectedObject of this stack to EMPTY\n   --   set the cTableName of this stack to EMPTY\n   \n   SaveStack the long id of this stack  // DatabaseDesignerLibrary\nend CloseStackRequestHandler\n\n\nsetProp cFieldType newValue\n   local stackReference\n   put word -2 to -1 of the long id of the target into stackReference\n   local databaseType\n   put the cDatabaseType of stackReference into databaseType\n   if (databaseType = \"SQLite\") then\n      DBModifyColumnForSQLite the cDatabaseID of stackReference, the cTableName of stackReference, the short name of the target, newValue\n   else\n      DBColumnModify the cDatabaseID of stackReference, the cTableName of stackReference, the short name of the target && newValue\n   end if\n   pass cFieldType\nend cFieldType\n\n\n// when changing the mode of the editor (browse or edit) \nsetProp cMode newValue\n   lock screen\n   \n   set the cMode of this stack to newValue\n   \n   local stackLeft\n   put the left of this stack into stackLeft\n   switch newValue\n      case \"browse\"         \n         set the width of this stack to 755\n         SwitchToBrowseMode\n         break\n      case \"edit\"\n         set the width of this stack to 1024\n         SwitchToEditMode\n         break\n   end switch\n   set the left of this stack to stackLeft\n   ToggleUserCheckboxAutoHilite the long id of this stack  // DatabaseDesignerLibrary\n   unlock screen\nend cMode\n\n\non MoveControl\n   if (the cMode of this stack = \"Edit\") then\n      SaveStack the long id of this stack  // DatabaseDesignerLibrary\n   end if\nend MoveControl\n\n\n// if the newName of the control is EMPTY set it to the oldName\non NameChanged oldName, newName\n   if (newName = EMPTY) then\n      set the name of the target to oldName\n   end if\n   pass NameChanged\nend NameChanged\n\n\non ResizeControl\n   if (the cMode of this stack = \"Edit\") then\n      SaveStack the long id of this stack  // DatabaseDesignerLibrary\n   end if\nend ResizeControl\n\n\ncommand SaveDatabaseColumns\n   if (the cDatabaseID of this stack is a number) then\n      local numberOfControls\n      put the number of controls into numberOfControls\n      repeat with i = 1 to numberOfControls\n         if (char 1 to 3 of the short name of control i <> \"dbd\") AND (the cControlType of control i <> \"label\") then\n            local columnSchema\n            put the short name of control i && the cFieldType of control i into columnSchema\n            if (the cAutoIncrement of control i) then put \" AUTOINCREMENT\" after columnSchema\n            if (the cNotNull of control i) then put \" NOT NULL\" after columnSchema\n            if (the cUnique of control i) then put \" UNIQUE\" after columnSchema\n            DBColumnRename the cDatabaseID of this stack, the cTableName of this stack, the cName of control i, the short name of control i\n            if (the result contains \"no such column\") then\n               DBColumnAdd the cDatabaseID of this stack, the cTableName of this stack, columnSchema\n               if (the cControlType of control i = \"checkbox\") then\n                  DBUpdate the cDatabaseID of this stack, the cTableName of this stack, the short name of control i, \\\n                        the hilite of control i, \"dbdID\", the cDBDID of this stack\n               end if\n            end if\n            set the cName of control i to (the short name of control i)\n         end if\n      end repeat\n   end if\n   DBCommit the cDatabaseID of this stack\nend SaveDatabaseColumns\n\n\ncommand SwitchToBrowseMode\n   if (DBRecordSetCount(the cRecordSetID of this stack) > 0) then\n      EnableFieldControls\n   end if\n   LockPictureLocation  // lock the picture rect so it doesn't change when an image is added\n   SaveDatabaseColumns\n   SaveStack the long id of this stack  // DatabaseDesignerLibrary\n   \n   SetNewRecordSetID the long id of this stack\n   \n   NavigationMoveToRecord the long id of this stack, (the text of field \"dbdCurrentRecord\" of this stack - 1)\n   \n   set the text of field \"dbdNumberOfRecords\" to (DBRecordSetCount(the cRecordSetID of this stack))\n   \n   disable group \"dbdTools\"\n   enable group \"dbdNavigationControls\"\n   set the backgroundColor of button \"dbdEditGroupBackground\" to \"white\"\n   \n   select empty\nend SwitchToBrowseMode\n\n\ncommand SwitchToEditMode   \n   select empty\n   DisableFieldControls  // DatabaseDesignerBehaviour\n   enable group \"dbdTools\"\n   disable group \"dbdNavigationControls\"\n   set the backgroundColor of button \"dbdEditGroupBackground\" to 254,248,218\nend SwitchToEditMode\n\n\ncommand DisableFieldControls\n   local numberOfControls\n   put the number of controls into numberOfControls\n   \n   repeat with i = 1 to numberOfControls\n      if (char 1 to 3 of the short name of control i <> \"dbd\") AND (the cControlType of control i <> \"label\") then\n         