<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<title>Dictionary</title>

	<link href="[[tDocsCSSFolder]]/bootstrap.min.css" rel="stylesheet">
	<link href="[[tDocsCSSFolder]]/lcdoc.css" rel="stylesheet">
	<link href="[[tDocsCSSFolder]]/codestyle.css" rel="stylesheet">
	<style>
		/* ── Light/dark mode via CSS custom properties ── */
		:root {
			--bg:              #ffffff;
			--bg-subtle:       #f5f5f5;
			--bg-raised:       #ffffff;
			--border:          #dddddd;
			--text:            #333333;
			--text-muted:      #777777;
			--link:            #337ab7;
			--navbar-bg:       #f8f8f8;
			--navbar-border:   #e7e7e7;
			--panel-head-bg:   #f5f5f5;
			--input-bg:        #ffffff;
			--input-border:    #cccccc;
			--hover-bg:        #f5f5f5;
			--selected-bg:     #d0e4f7;
			--selected-text:   #333333;
			--dropdown-bg:     #ffffff;
			--dropdown-border: #cccccc;
			--scrollbar-track: #f5f5f5;
			--scrollbar-thumb: #c1c1c1;
		}

		@media (prefers-color-scheme: dark) {
			:root {
				--bg:              #1e1e1e;
				--bg-subtle:       #252526;
				--bg-raised:       #2d2d30;
				--border:          #3e3e42;
				--text:            #d4d4d4;
				--text-muted:      #858585;
				--link:            #4da6ff;
				--navbar-bg:       #252526;
				--navbar-border:   #3e3e42;
				--panel-head-bg:   #2d2d30;
				--input-bg:        #3c3c3c;
				--input-border:    #555555;
				--hover-bg:        #2d2d30;
				--selected-bg:     #094771;
				--selected-text:   #d4d4d4;
				--dropdown-bg:     #2d2d30;
				--dropdown-border: #3e3e42;
				--scrollbar-track: #1e1e1e;
				--scrollbar-thumb: #555555;
			}
		}

		body {
			background-color: var(--bg);
			color: var(--text);
		}

		/* Navbar */
		.navbar-default {
			background-color: var(--navbar-bg);
			border-color: var(--navbar-border);
		}
		.navbar-default .navbar-text,
		.navbar-default .navbar-nav > li > a,
		.navbar-default .navbar-nav > li > a:focus {
			color: var(--text);
		}
		.navbar-default .navbar-nav > li > a:hover {
			color: var(--text);
			background-color: var(--hover-bg);
		}
		.navbar-default .navbar-form .form-control {
			background-color: var(--input-bg);
			border-color: var(--input-border);
			color: var(--text);
		}

		/* Buttons */
		.btn-default {
			background-color: var(--bg-raised);
			border-color: var(--border);
			color: var(--text);
		}
		.btn-default:hover,
		.btn-default:focus,
		.btn-default:active,
		.open > .dropdown-toggle.btn-default {
			background-color: var(--hover-bg);
			border-color: var(--border);
			color: var(--text);
		}

		/* Panels */
		.panel-default {
			background-color: var(--bg-raised);
			border-color: var(--border);
		}
		.panel-default > .panel-heading {
			background-color: var(--panel-head-bg);
			border-color: var(--border);
			color: var(--text);
		}
		.panel-body {
			background-color: var(--bg-raised);
			color: var(--text);
		}

		/* Tables */
		.table {
			color: var(--text);
		}
		.table > thead > tr > th,
		.table > tbody > tr > td {
			border-color: var(--border);
			color: var(--text);
		}
		.table-hover > tbody > tr:hover > td,
		.table-hover > tbody > tr:hover > th {
			background-color: var(--hover-bg);
			color: var(--text);
		}
		/* Selected / active row */
		.table > tbody > tr.active > td,
		.table > tbody > tr.active > th,
		.table > tbody > tr > td.active,
		.table > thead > tr.active > th {
			background-color: var(--selected-bg) !important;
			color: var(--selected-text) !important;
		}

		/* Forms */
		.form-control {
			background-color: var(--input-bg);
			border-color: var(--input-border);
			color: var(--text);
		}
		.form-control:focus {
			background-color: var(--input-bg);
			color: var(--text);
		}
		.form-control::placeholder {
			color: var(--text-muted);
		}

		/* Dropdowns */
		.dropdown-menu {
			background-color: var(--dropdown-bg);
			border-color: var(--dropdown-border);
		}
		.dropdown-menu > li > a {
			color: var(--text);
		}
		.dropdown-menu > li > a:hover,
		.dropdown-menu > li > a:focus {
			background-color: var(--hover-bg);
			color: var(--text);
		}
		.dropdown-menu .divider {
			background-color: var(--border);
		}

		/* Links */
		a { color: var(--link); }

		/* Code blocks */
		pre, code {
			background-color: var(--bg-subtle);
			border-color: var(--border);
			color: var(--text);
		}

		/* Panel resizer / splitter */
		#resizer {
			background-color: var(--border);
			border-top-color: var(--border);
			border-bottom-color: var(--border);
		}
		#resizer:hover {
			background-color: var(--link);
		}

		/* Table header (sticky column headers above the list) */
		/* !important needed to override lcdoc.css's hardcoded #FFFFFF on #header_panel_holder */
		#table_header,
		#table_container,
		#header_panel_holder {
			background-color: var(--bg-raised) !important;
		}
		#table_list_header > thead > tr > th,
		#table_list_header > tbody > tr > th,
		#table_list_header > tbody > tr > td {
			background-color: var(--bg-raised) !important;
			color: var(--text);
			border-color: var(--border);
		}

		/* Spacer below navbar */
		#docs-spacer {
			background-color: var(--bg);
		}

		/* Container backgrounds */
		.container-fluid,
		.bs-docs-container,
		.bs-sidebar {
			background-color: var(--bg);
		}

		/* Scrollbars (WebKit/WKWebView) */
		::-webkit-scrollbar { width: 8px; height: 8px; }
		::-webkit-scrollbar-corner { background: var(--scrollbar-track); }
		::-webkit-scrollbar-track { background: var(--scrollbar-track); }
		::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 4px; }

		/* Invert the resizer PNG in dark mode so the light image becomes dark */
		@media (prefers-color-scheme: dark) {
			#resizer { filter: invert(1); }
		}
	</style>
</head>
<body>

<nav class="navbar navbar-default navbar-fixed-top" id="lcnavbar">
	<div class="navbar-header">
		<button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar" aria-expanded="false" aria-controls="navbar">
			<span class="sr-only">Toggle navigation</span>
			<span class="icon-bar"></span>
			<span class="icon-bar"></span>
			<span class="icon-bar"></span>
		</button>
		<!--<div class="navbar-brand">API</div>-->
	</div>
	<div class="collapse navbar-collapse" id="navbar">
		<ul class="nav navbar-nav col-md-5">
			<li>
				<p class="navbar-text">Choose API:</p>
			</li>
			<li class="dropdown">
				<button class="btn btn-default btn-sm dropdown-toggle navbar-btn" type="button" id="dropdownMenu1" data-toggle="dropdown" aria-expanded="true">
					<span id="lcdoc_library_chooser_text"></span>
					<span class="caret"></span>
				</button>
			<ul class="dropdown-menu" role="menu" aria-labelledby="dropdownMenu1" id="lcdoc_library_chooser_list">
			</ul>
			</li>
		</ul>
		<ul class="nav navbar-nav col-md-3">
			<li id="lcdoc_history_back">
				<a href="#">
					<span aria-hidden="true" class="glyphicon glyphicon-chevron-left"></span>
					<span class="sr-only">Previous</span>
				</a>
			</li>
			<li id="lcdoc_history_forward">
				<a href="#">
					<span aria-hidden="true" class="glyphicon glyphicon-chevron-right"></span>
					<span class="sr-only">Next</span>
				</a>
			</li>
			<li id="lcdoc_history" class="dropdown">
				<a href="#" class="dropdown-toggle" data-toggle="dropdown">
					<span class="glyphicon glyphicon-time" id="dropdownMenu2" aria-expanded="true"></span>
				</a>
				<ul class="dropdown-menu" role="menu" aria-labelledby="dropdownMenu2" id="lcdoc_history_list">
				</ul>
			</li>
		</ul>
		<form class="navbar-form navbar-right col-md-4">
			<div class="form-group" id="filter_box">
			  <input id="ui_filer" type="text" class="form-control input-sm" spellcheck="false" placeholder="Search">
			</div>
			<button type="button" class="btn btn-default btn-sm"><span class="glyphicon glyphicon-search"></span></button>
		</form>
	</div><!-- /.navbar-collapse -->
</nav>

<div class="container-fluid bs-docs-container" >
<div id="docs-spacer" style="height:15px; z-index:200;"></div>

	<div class="row">
		<div class="col-md-3">
			<div class="bs-sidebar" id="lcdoc_sidebar">
				<div class="panel panel-default" id="filters_panel">
					<div class="panel-heading">Filters</div>
					<div class="panel-body" id="filters_container">
						<div id="filters">none</div>
						<div id="filters_options"></div>
					</div>
				</div>
			</div>
		</div>
 
		<div class="col-md-9">
			<div id="header_panel_holder">
				<div class="panel panel-default" id="lcdoc_list">
					<div id="table_header">
						<table class="table table-hover table-condensed" id="table_list_header">
						</table>
					</div>
					<div id="table_container">
						<table class="table table-hover table-condensed" id="table_list">
						</table>
					</div>
					<!-- header panel resizer -->
					<div id="resizer">
					</div>
				</div>
			</div>

			<div class="panel panel-default" id="lcdoc_body">
				<div class="panel-body" id="api_entry">
				</div>

			</div>
		</div>
	</div>
</div>

	<script src="[[tDocsJSFolder]]/jquery-1.11.1.min.js"></script>
	<script src="[[tDocsJSFolder]]/jquery.session.js"></script>
	<script src="[[tDocsJSFolder]]/bootstrap.min.js"></script>
	<script src="[[tDocsJSFolder]]/marked.js"></script>
	<script src="[[tDocsJSFolder]]/highlight.pack.js"></script>	
	<script src="[[tDocsJSFolder]]/jquery.mousewheel.min.js"></script>	

	<script charset="UTF-8" src="[[tDataPath]]"></script>  
	<script src="[[tDocsJSFolder]]/dictionary_functions.js"></script>	
	<script>
		$(document).ready(function(e)
		{
			setEdition('[[ the editionType]]');
			setActions();
			dataFilter();
			displayLibraryChooser();

			goEntryName('[[tLibraryName]]', '[[tEntryName]]', '[[tEntryType]]');
			document.getElementById("ui_filer").focus();

			// Notify script that the page is ready.
			// browserNavigateComplete callbacks are unavailable via libffi;
			// use the JS bridge instead.
			if (typeof liveCode !== 'undefined') {
				liveCode.browserNavigateComplete();
			}
		});
	</script>
</body>
</html>
